# Signed 64-bit integer.
# Here `as-bytes` must be a `bytes` object.

+architect yegor256@gmail.com
+home https://github.com/objectionary/eo
+rt jvm org.eolang:eo-runtime:0.0.0
+rt node eo2js-runtime:0.0.0
+version 0.0.0
+spdx SPDX-FileCopyrightText: Copyright (c) 2016-2026 Objectionary.com
+spdx SPDX-License-Identifier: MIT
+unlint redundant-object
+unlint mandatory-package

[as-bytes] > i64
  as-bytes > @
  as-i32.as-i16 > as-i16
  times -1.as-i64 > neg

  [cant-convert] > as-i32
    if. > @
      ^.eq left.as-i64
      left
      cant-convert
        "Can't convert i64 number %d to i32 because it's out of i32 bounds".printf
          * as-number
    i32 (as-bytes.slice 4 4) > left

  [] > as-number /number

  [x] > lt
    gt. > @
      i64 x.as-bytes
      ^

  [x] > lte
    or. > @
      lt value
      ^.eq value
    x > value!

  [x] > gt
    if. > @
      differ
      positive
      and.
        greater
        (difference.as-bytes.eq zero).not
    ^.minus x > difference
    00-00-00-00-00-00-00-00 > zero
    80-00-00-00-00-00-00-00 > mask
    ^.as-bytes.and mask > sign
    not. > differ
      eq.
        sign
        x.as-bytes.and mask
    sign.eq zero > positive
    (difference.as-bytes.and mask).eq zero > greater

  [x] > gte
    or. > @
      gt value
      ^.eq value
    x > value!

  [x] > times
    looped 00-00-00-00-00-00-00-00 as-bytes x.as-bytes > @
    [acc a b] > looped
      if. > @
        b.eq 00-00-00-00-00-00-00-00
        i64 acc
        looped
          if.
            (b.and 00-00-00-00-00-00-00-01).eq 00-00-00-00-00-00-00-01
            ((i64 acc).plus (i64 a)).as-bytes
            acc
          a.left 1
          b.right 1

  [x] > plus /i64

  [x] > minus
    plus (i64 value).neg > @
    x > value!

  [x] > div /i64
    ? > cant-divide /{string}

  ++> tests-i64-has-valid-bytes
    eq. > @
      42.as-i64.as-bytes
      00-00-00-00-00-00-00-2A

  ++> tests-i64-as-bytes-is-not-equal-to-number-bytes
    not. > @
      eq.
        i64 234.as-bytes
        234.as-i64.as-bytes

  ++> tests-i64-to-i32-and-back
    eq. > @
      234.as-i64
      234.as-i64.as-i32.as-i64

  ++> tests-negative-i64-to-i32-and-back
    eq. > @
      -234.as-i64
      -234.as-i64.as-i32.as-i64

  3147483647.as-i64.as-i32 > [] -> on-converting-to-i32-if-out-of-bounds

  ++> tests-out-of-bounds-i64-as-i32-returns-provided-fallback
    eq. > @
      "recovered"
      3147483647.as-i64.as-i32
        "recovered" > [msg]

  ++> tests-i64-i32-max-converts-without-error
    eq. > @
      2147483647.as-i64
      2147483647.as-i64.as-i32.as-i64

  ++> tests-i64-i32-min-converts-without-error
    eq. > @
      -2147483648.as-i64
      -2147483648.as-i64.as-i32.as-i64

  2147483648.as-i64.as-i32 > [] -> on-converting-i32-max-plus-one-to-i32

  -2147483649.as-i64.as-i32 > [] -> on-converting-i32-min-minus-one-to-i32

  ++> tests-i64-less-true
