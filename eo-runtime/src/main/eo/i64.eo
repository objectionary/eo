      lt.
        10.as-i64
        -5.as-i64

  ++> tests-i64-less-across-full-range
    lt. > @
      -9.223372036854776E18.as-i64
      1.as-i64

  ++> tests-i64-less-with-large-difference
    not. > @
      lt.
        5000000000000000000.as-i64
        -5000000000000000000.as-i64

  ++> tests-i64-greater-true
    gt. > @
      -200.as-i64
      -1000.as-i64

  ++> tests-i64-greater-false
    not. > @
      gt.
        0.as-i64
        100.as-i64

  ++> tests-i64-greater-equal
    not. > @
      gt.
        0.as-i64
        0.as-i64

  ++> tests-i64-greater-max-over-min
    gt. > @
      i64 7F-FF-FF-FF-FF-FF-FF-FF
      i64 80-00-00-00-00-00-00-00

  ++> tests-i64-greater-min-not-over-max
    not. > @
      gt.
        i64 80-00-00-00-00-00-00-00
        i64 7F-FF-FF-FF-FF-FF-FF-FF

  ++> tests-i64-greater-same-sign-large-negatives
