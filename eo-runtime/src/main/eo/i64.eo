# Signed 64-bit integer.
# Here `as-bytes` must be a `bytes` object.

+architect yegor256@gmail.com
+home https://github.com/objectionary/eo
+rt jvm org.eolang:eo-runtime:0.0.0
+rt node eo2js-runtime:0.0.0
+version 0.0.0
+spdx SPDX-FileCopyrightText: Copyright (c) 2016-2026 Objectionary.com
+spdx SPDX-License-Identifier: MIT
+unlint redundant-object
+unlint mandatory-package

[as-bytes] > i64
  as-bytes > @
  as-i32.as-i16 > as-i16
  [cant-convert] > as-i32
    if. > @
      ^.eq left.as-i64
      left
      cant-convert
        "Can't convert i64 number %d to i32 because it's out of i32 bounds".printf
          * as-number
    i32 > left
      as-bytes.slice 4 4
  [] > as-number /Q.number
  [x cant-divide] > div
    if. > @
      x.as-bytes.eq 00-00-00-00-00-00-00-00
      cant-divide
        "i64 cannot be divided by zero"
      result
    00-00-00-00-00-00-00-01.left i > [i] > bit
    magnitude x.as-bytes > bottom
    as-bytes. > bottom-negated
      plus.
        i64 bottom.not
        i64 00-00-00-00-00-00-00-01
    [idx rem quot] > looped
      if. > @
        idx.lt 0
        quot
        unsigned-gte.if
          looped
            idx.minus 1
            next-rem
            next-quot
          looped
            idx.minus 1
            shifted
            quot
      shifted-sign.and divisor-sign > both-negative!
      both-negative.or mixed-signs-with-nonneg-trial > carry-out!
      bottom-negated.and 80-00-00-00-00-00-00-00 > divisor-sign!
      signs-differ.and trial-nonnegative > mixed-signs-with-nonneg-trial!
      quot.or > next-quot!
        bit idx
      as-bytes. > next-rem!
        plus.
          i64 shifted
          i64 bottom-negated
      or. > shifted!
        rem.left 1
        and.
          top.right idx
          00-00-00-00-00-00-00-01
      shifted.and 80-00-00-00-00-00-00-00 > shifted-sign!
      shifted-sign.xor divisor-sign > signs-differ!
      next-rem.xor 80-00-00-00-00-00-00-00 > trial-nonnegative!
      carry-out.eq 80-00-00-00-00-00-00-00 > unsigned-gte
    if. > [b] > magnitude
      eq.
        b.and 80-00-00-00-00-00-00-00
        80-00-00-00-00-00-00-00
      as-bytes.
        plus.
          i64 b.not
          i64 00-00-00-00-00-00-00-01
      b
    eq. > negative
      and.
        as-bytes.xor x.as-bytes
        80-00-00-00-00-00-00-00
      80-00-00-00-00-00-00-00
    looped > quotient
      63
      00-00-00-00-00-00-00-00
      00-00-00-00-00-00-00-00
    negative.if > result
      as-bytes.
        plus.
          i64 quotient.not
          i64 00-00-00-00-00-00-00-01
      i64 quotient
    magnitude as-bytes > top
  [x] > gt
    differ.if > @
      positive
      greater.and
        not.
          difference.as-bytes.eq zero
    not. > differ
      sign.eq
        x.as-bytes.and mask
    minus x > difference
    eq. > greater
      difference.as-bytes.and mask
      zero
    80-00-00-00-00-00-00-00 > mask
    sign.eq zero > positive
    as-bytes.and mask > sign
    00-00-00-00-00-00-00-00 > zero
  [x] > gte
    or. > @
      gt value
      ^.eq value
    x > value!
  gt. > [x] > lt
    i64 x.as-bytes
    ^
  [x] > lte
    or. > @
      lt value
      ^.eq value
    x > value!
  [x] > minus
    plus > @
      neg.
        i64 value
    x > value!
  times -1.as-i64 > neg
  [x] > plus
    carried > @
      as-bytes
      x.as-bytes
    if. > [a b] > carried
      b.eq 00-00-00-00-00-00-00-00
      i64 a
      carried
        a.xor b
        left.
          a.and b
          1
  [x] > times
    if. > [acc a b] > looped
      b.eq 00-00-00-00-00-00-00-00
      i64 acc
      looped
        if.
          (b.and 00-00-00-00-00-00-00-01).eq 00-00-00-00-00-00-00-01
          as-bytes.
            (i64 acc).plus
              i64 a
          acc
        a.left 1
        b.right 1
    | > @
      00-00-00-00-00-00-00-00
      as-bytes
      x.as-bytes

