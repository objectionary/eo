      0.as-i64

  ++> tests-i64-times-of-two-negatives
    eq. > @
      -7.as-i64.times -6.as-i64
      42.as-i64

  ++> tests-i64-times-of-mixed-signs
    eq. > @
      -7.as-i64.times 6.as-i64
      -42.as-i64

  ++> tests-i64-times-wraps-modulo-2-pow-64
    eq. > @
      (i64 40-00-00-00-00-00-00-00).times 4.as-i64
      0.as-i64

  ++> tests-i64-times-keeps-low-bits-of-large-product
    eq. > @
      2147483647.as-i64.times 2147483647.as-i64
      i64 3F-FF-FF-FF-00-00-00-01
