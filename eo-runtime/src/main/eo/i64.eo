        as-i64. -7
        as-i64. -6
      as-i64. 42

  ++> tests-i64-times-of-mixed-signs
    eq. > @
      times.
        as-i64. -7
        as-i64. 6
      as-i64. -42

  ++> tests-i64-times-wraps-modulo-2-pow-64
    eq. > @
      times.
        i64 40-00-00-00-00-00-00-00
        as-i64. 4
      as-i64. 0

  ++> tests-i64-times-keeps-low-bits-of-large-product
    eq. > @
      times.
        as-i64. 2147483647
        as-i64. 2147483647
      i64 3F-FF-FF-FF-00-00-00-01
