# Signed 64-bit integer.
# Here `as-bytes` must be a `bytes` object.

+architect yegor256@gmail.com
+home https://github.com/objectionary/eo
+rt jvm org.eolang:eo-runtime:0.0.0
+rt node eo2js-runtime:0.0.0
+version 0.0.0
+spdx SPDX-FileCopyrightText: Copyright (c) 2016-2026 Objectionary.com
+spdx SPDX-License-Identifier: MIT
+unlint redundant-object
+unlint mandatory-package

[as-bytes] > i64
  as-bytes > @
  as-i32.as-i16 > as-i16
  times -1.as-i64 > neg
  [cant-convert] > as-i32
    if. > @
      ^.eq left.as-i64
      left
      cant-convert
        "Can't convert i64 number %d to i32 because it's out of i32 bounds".printf
          * as-number
    i32 > left
      as-bytes.slice 4 4
  [] > as-number /Q.number
  gt. > [x] > lt
    i64 x.as-bytes
    ^
  [x] > lte
    or. > @
      lt value
      ^.eq value
    x > value!
  [x] > gt
    differ.if > @
      positive
      greater.and
        not.
          difference.as-bytes.eq zero
    minus x > difference
    00-00-00-00-00-00-00-00 > zero
    80-00-00-00-00-00-00-00 > mask
    as-bytes.and mask > sign
    not. > differ
      sign.eq
        x.as-bytes.and mask
    sign.eq zero > positive
    eq. > greater
      difference.as-bytes.and mask
      zero
  [x] > gte
    or. > @
      gt value
      ^.eq value
    x > value!
  [x] > times
    if. > [acc a b] > looped
      b.eq 00-00-00-00-00-00-00-00
      i64 acc
      looped
        if.
          (b.and 00-00-00-00-00-00-00-01).eq 00-00-00-00-00-00-00-01
          as-bytes.
            (i64 acc).plus
              i64 a
          acc
        a.left 1
        b.right 1
    | > @
      00-00-00-00-00-00-00-00
      as-bytes
      x.as-bytes
  [x] > plus /Q.i64
  [x] > minus
    plus > @
      neg.
        i64 value
    x > value!
  [x] > div /Q.i64
    ? > cant-divide /{Q.string}

  42.as-i64.as-bytes.eq 00-00-00-00-00-00-00-2A ++> tests-i64-has-valid-bytes

  ++> tests-i64-as-bytes-is-not-equal-to-number-bytes
    not. > @
      eq.
        i64 234.as-bytes
        234.as-i64.as-bytes

  234.as-i64.eq 234.as-i64.as-i32.as-i64 ++> tests-i64-to-i32-and-back

  -234.as-i64.eq -234.as-i64.as-i32.as-i64 ++> tests-negative-i64-to-i32-and-back

  3147483647.as-i64.as-i32 --> on-converting-to-i32-if-out-of-bounds

  ++> tests-out-of-bounds-i64-as-i32-returns-provided-fallback
