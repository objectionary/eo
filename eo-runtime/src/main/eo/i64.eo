      as-i64. 2
      as-i64. 0

  ++> tests-i64-div-by-zero-returns-provided-fallback
    eq. > @
      "recovered"
      div.
        as-i64. 2
        as-i64. 0
        "recovered" > [msg]

  ++> tests-i64-div-by-i64-one
    eq. > @
      dividend.div
        as-i64. 1
      dividend
    as-i64. -235 > dividend

  ++> tests-i64-div-with-remainder
    eq. > @
      div.
        as-i64. 13
        as-i64. -5
      as-i64. -2

  ++> tests-i64-div-less-than-i64-one
    lt. > @
      div.
        as-i64. 1
        as-i64. 5
      as-i64. 1

  ++> tests-i64-multiply-by-zero
    eq. > @
      times.
        as-i64. 1000
        as-i64. 0
      as-i64. 0

  ++> tests-i64-times-of-two-negatives
    eq. > @
