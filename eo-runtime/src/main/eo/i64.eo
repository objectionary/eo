      -5000000000000000000.as-i64
      -9000000000000000000.as-i64

  ++> tests-i64-lte-true
    lte. > @
      -200.as-i64
      -100.as-i64

  ++> tests-i64-lte-equal
    lte. > @
      50.as-i64
      50.as-i64

  ++> tests-i64-lte-false
    not. > @
      lte.
        0.as-i64
        -10.as-i64

  ++> tests-i64-gte-true
    gte. > @
      -1000.as-i64
      -1100.as-i64

  ++> tests-i64-gte-equal
    gte. > @
      113.as-i64
      113.as-i64

  ++> tests-i64-gte-false
    not. > @
      gte.
        0.as-i64
        10.as-i64

  ++> tests-i64-zero-eq-to-i64-zero
    eq. > @
      0.@
      0.@

  ++> tests-i64-eq-true
    eq. > @
      123.@
      123.@

  ++> tests-i64-eq-false
