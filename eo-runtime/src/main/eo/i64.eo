  -200.as-i64.gt -1000.as-i64 ++> tests-i64-greater-true

  (0.as-i64.gt 100.as-i64).not ++> tests-i64-greater-false

  (0.as-i64.gt 0.as-i64).not ++> tests-i64-greater-equal

  gt. ++> tests-i64-greater-max-over-min
