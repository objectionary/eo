  ++> tests-calculates-fibonacci-number-with-recursion
    eq. > @
      fibo 4
      3
    if. > [n] > fibo
      n.lt 3
      1
      plus.
        fibo
          n.minus 1
        fibo
          n.minus 2

  ++> tests-calculates-fibonacci-number-with-tail
    eq. > @
      fibonacci 4
      3
    [n] > fibonacci
      if. > @
        n.lt 3
        small n
        rec
          n
          1
          1
      if. > [n] > small
        n.eq 2
        1
        n
      if. > [n minus1 minus2] > rec
        n.eq 3
        minus1.plus minus2
        rec
          n.minus 1
          minus1.plus minus2
          minus1

  seq * ++> tests-zero-division
